<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 状态卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_inactive"
                    android:textColor="@color/status_inactive"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_status_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/pref_scope_desc"
                    android:textColor="#888888"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 主开关 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_global_enable"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_global_enable_desc"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_enable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 模糊引擎选择卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_engine_title"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radio_group_engine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_auto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_engine_auto"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:padding="4dp" />

                    <RadioButton
                        android:id="@+id/radio_window"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_engine_window"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:padding="4dp" />

                    <RadioButton
                        android:id="@+id/radio_kawase"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_engine_kawase"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:padding="4dp" />

                </RadioGroup>

                <TextView
                    android:id="@+id/tv_engine_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="当前引擎: 自动"
                    android:textColor="#888888"
                    android:textSize="12sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 模糊参数卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="模糊参数"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- 竖屏模糊半径 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_blur_portrait"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_blur_portrait"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/tv_blur_portrait"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="20"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 横屏模糊半径 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_blur_landscape"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_blur_landscape"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/tv_blur_landscape"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 模糊 Pass 次数 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_pass_count"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_pass_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="1"
                        android:valueTo="6"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/tv_pass_count"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 饱和度 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_saturation"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_saturation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="2"
                        android:stepSize="0.1" />

                    <TextView
                        android:id="@+id/tv_saturation"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="1.0"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 亮度 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_brightness"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_brightness"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0.5"
                        android:valueTo="1.5"
                        android:stepSize="0.1" />

                    <TextView
                        android:id="@+id/tv_brightness"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="1.0"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 遮罩透明度（新） -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_overlay_alpha_new"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_overlay_alpha_new"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/tv_overlay_alpha_new"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 遮罩透明度（原有） -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_overlay_alpha"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_overlay_alpha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/tv_overlay_alpha"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 背景变暗量 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_dim_amount"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_dim_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/tv_dim_amount"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 圆角卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 圆角开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_corner_enable"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_corner_enable_desc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_corner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- 圆角半径 -->
                <LinearLayout
                    android:id="@+id/layout_corner_radius"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_corner_radius"
                        android:textColor="#AAAAAA"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_corner_radius"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0"
                            android:valueTo="100"
                            android:stepSize="1" />

                        <TextView
                            android:id="@+id/tv_corner_radius"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="50"
                            android:textColor="@color/accent"
                            android:textSize="14sp"
                            android:gravity="center" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 高光卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 高光开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_gloss_enable"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pref_gloss_enable_desc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_gloss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- 高光参数 -->
                <LinearLayout
                    android:id="@+id/layout_gloss"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <!-- 高光透明度 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_gloss_alpha"
                        android:textColor="#AAAAAA"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_gloss_alpha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0"
                            android:valueTo="100"
                            android:stepSize="1" />

                        <TextView
                            android:id="@+id/tv_gloss_alpha"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="30"
                            android:textColor="@color/accent"
                            android:textSize="14sp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- 高光宽度 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_gloss_width"
                        android:textColor="#AAAAAA"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_gloss_width"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="10"
                            android:valueTo="200"
                            android:stepSize="1" />

                        <TextView
                            android:id="@+id/tv_gloss_width"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="60"
                            android:textColor="@color/accent"
                            android:textSize="14sp"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 操作按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_restart_ime"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/btn_restart_ime"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:text="在 LSPosed 管理器中勾选需要生效的输入法应用"
            android:textColor="#666666"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
